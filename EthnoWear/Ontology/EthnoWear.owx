<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#"
     xml:base="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear"
     xmlns:ew="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#belongsToRegionGroup -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#belongsToRegionGroup">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasRegionMember"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#RegionGroup"/>
        <rdfs:label xml:lang="en">belongs to region group</rdfs:label>
        <rdfs:label xml:lang="bg">принадлежи към група региони</rdfs:label>
        <skos:altLabel xml:lang="bg">принадлежи към група райони</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasColor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasColor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isColorOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color"/>
        <rdfs:label xml:lang="en">has color</rdfs:label>
        <rdfs:label xml:lang="bg">има цвят</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasMotif -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasMotif">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isMotifOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:label xml:lang="en">has motif</rdfs:label>
        <rdfs:label xml:lang="bg">има мотив</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasOrnament -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasOrnament">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isOrnamentOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Ornament"/>
        <rdfs:label xml:lang="en">has ornament</rdfs:label>
        <rdfs:label xml:lang="bg">има орнамент</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasRegion -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasRegion">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isRegionOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:label xml:lang="en">has region</rdfs:label>
        <rdfs:label xml:lang="bg">има регион</rdfs:label>
        <skos:altLabel xml:lang="bg">има район</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasRegionMember -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasRegionMember">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#RegionGroup"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:label xml:lang="en">has region member</rdfs:label>
        <rdfs:label xml:lang="bg">има регион</rdfs:label>
        <skos:altLabel xml:lang="bg">включва район</skos:altLabel>
        <skos:altLabel xml:lang="bg">включва регион</skos:altLabel>
        <skos:altLabel xml:lang="bg">има район</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasTechnique -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasTechnique">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isTechniqueOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Technique"/>
        <rdfs:label xml:lang="en">has technique</rdfs:label>
        <rdfs:label xml:lang="bg">има техника</rdfs:label>
        <skos:altLabel xml:lang="bg">има бод</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isCharacteristicColorOfRegion -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isCharacteristicColorOfRegion">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesColor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:label xml:lang="en">is characteristic color of region</rdfs:label>
        <rdfs:label xml:lang="bg">е характерен цвят за регион</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isCharacteristicOrnamentOfRegion -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isCharacteristicOrnamentOfRegion">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesOrnament"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Ornament"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:label xml:lang="en">is characteristic ornament of region</rdfs:label>
        <rdfs:label xml:lang="bg">е характерен орнамент за регион</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isCharacteristicTechniqueOfRegion -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isCharacteristicTechniqueOfRegion">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesTechnique"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Technique"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:label xml:lang="en">is characteristic technique of region</rdfs:label>
        <rdfs:label xml:lang="bg">е характерна техника за регион</rdfs:label>
        <skos:altLabel xml:lang="bg">е характерен бод за регион</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isColorOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isColorOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:label xml:lang="en">is color of</rdfs:label>
        <rdfs:label xml:lang="bg">е цвят на</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isColorOfMotif -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isColorOfMotif">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasColor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:label xml:lang="en">is color of motif</rdfs:label>
        <rdfs:label xml:lang="bg">е цвят на мотив</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isMotifOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isMotifOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:label xml:lang="en">is motif of</rdfs:label>
        <rdfs:label xml:lang="bg">е мотив на</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isOrnamentOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isOrnamentOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Ornament"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:label xml:lang="en">is ornament of</rdfs:label>
        <rdfs:label xml:lang="bg">е орнамент на</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isOrnamentOfMotif -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isOrnamentOfMotif">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasOrnament"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Ornament"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:label xml:lang="en">is ornament of motif</rdfs:label>
        <rdfs:label xml:lang="bg">е орнамент на мотив</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isRegionOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isRegionOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:label xml:lang="en">is region of</rdfs:label>
        <rdfs:label xml:lang="bg">е регион на</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isTechniqueOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isTechniqueOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Technique"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Embroidery"/>
        <rdfs:label xml:lang="en">is technique of</rdfs:label>
        <rdfs:label xml:lang="bg">е техника на</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isTechniqueOfMotif -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#isTechniqueOfMotif">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasTechnique"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Technique"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:label xml:lang="en">is technique of motif</rdfs:label>
        <rdfs:label xml:lang="bg">е техника на мотив</rdfs:label>
        <skos:altLabel xml:lang="bg">е бод на мотив</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasColor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasColor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color"/>
        <rdfs:label xml:lang="en">motif has color</rdfs:label>
        <rdfs:label xml:lang="bg">мотивът има цвят</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasOrnament -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasOrnament">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Ornament"/>
        <rdfs:label xml:lang="en">motif has ornament</rdfs:label>
        <rdfs:label xml:lang="bg">мотивът има орнамент</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasTechnique -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#motifHasTechnique">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Motif"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Technique"/>
        <rdfs:label xml:lang="en">motif has technique</rdfs:label>
        <rdfs:label xml:lang="bg">мотивът има техника</rdfs:label>
        <skos:altLabel xml:lang="bg">мотивът има бод</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesColor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesColor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color"/>
        <rdfs:label xml:lang="en">region uses color</rdfs:label>
        <rdfs:label xml:lang="bg">регионът използва цвят</rdfs:label>
        <skos:altLabel xml:lang="bg">районът използва цвят</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesOrnament -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesOrnament">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Ornament"/>
        <rdfs:label xml:lang="en">region uses ornament</rdfs:label>
        <rdfs:label xml:lang="bg">регионът използва орнамент</rdfs:label>
        <skos:altLabel xml:lang="bg">районът използва орнамент</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesTechnique -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#regionUsesTechnique">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Region"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Technique"/>
        <rdfs:label xml:lang="en">region uses technique</rdfs:label>
        <rdfs:label xml:lang="bg">регионът използва техника</rdfs:label>
        <skos:altLabel xml:lang="bg">регионът използва бод</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#AnimalOrnament -->

    <owl:Class rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#AnimalOrnament">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Ornament"/>
        <rdfs:comment xml:lang="en">An ornament inspired by animals, birds, or stylized animal forms.</rdfs:comment>
        <rdfs:comment xml:lang="bg">Орнамент, вдъхновен от животни, птици или стилизирани животински форми.</rdfs:comment>
        <rdfs:label xml:lang="en">Animal ornament</rdfs:label>
        <rdfs:label xml:lang="bg">Животински орнамент</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color -->

    <owl:Class rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#Color">
        <rdfs:comment xml:lang="en">A color or color group used in traditional Bulgarian embroidery.</rdfs:comment>
        <rdfs:comment xml:lang="bg">Цвят или група от цветове, използвани в традиционната българска шевица.</rdfs:comment>
        <rdfs:label xml:lang="en">Color</rdfs:label>
        <rdfs:label xml:lang="bg">Цвят</rdfs:label>
        <skos:altLabel xml:lang="en">colour</skos:altLabel>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#DedeagachEmbroidery -->

    <owl:Class rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#DedeagachEmbroidery">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#RegionalEmbroidery"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasRegion"/>
                <owl:hasValue rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#DedeagachRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Dedeagach embroidery</rdfs:label>
        <rdfs:label xml:lang="bg">Дедеагачка шевица</rdfs:label>
        <skos:altLabel xml:lang="bg">Дедеагачка бродерия</skos:altLabel>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#DimotikaEmbroidery -->

    <owl:Class rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#DimotikaEmbroidery">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#RegionalEmbroidery"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#hasRegion"/>
                <owl:hasValue rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#DimotikaRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Dimotika embroidery</rdfs:label>
        <rdfs:label xml:lang="bg">Димотишка шевица</rdfs:label>
        <skos:altLabel xml:lang="bg">Димотишка бродерия</skos:altLabel>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#ElhovoEmbroidery -->

    <owl:Class rdf:about="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#ElhovoEmbroidery">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athan/ontologies/2026/4/ethno-wear#RegionalEmbroidery"/>
        <rdfs:subClassOf>
