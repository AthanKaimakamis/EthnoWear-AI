    <ew:regionUsesOrnament rdf:resource="#FlowerOrnament"/>
    <ew:regionUsesOrnament rdf:resource="#RhombusOrnament"/>
    <ew:regionUsesOrnament rdf:resource="#VineOrnament"/>
