    <rdfs:label xml:lang="bg">Добруджански регион</rdfs:label>
    <skos:altLabel xml:lang="bg">Добруджа</skos:altLabel>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#DoubleHeadedBirdOrnament">
    <rdf:type rdf:resource="#AnimalOrnament"/>
    <rdf:type rdf:resource="#SymbolicOrnament"/>
    <rdfs:label xml:lang="en">double-headed bird ornament</rdfs:label>
    <rdfs:label xml:lang="bg">орнамент двуглава птица</rdfs:label>
    <skos:altLabel xml:lang="bg">двуглав орел</skos:altLabel>
    <skos:altLabel xml:lang="bg">двуглава птица</skos:altLabel>
  </owl:NamedIndividual>

